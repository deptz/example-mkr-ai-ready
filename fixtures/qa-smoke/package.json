{
  "name": "qa-tasks-playwright",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "codegen": "playwright codegen ${PLAYWRIGHT_BASE_URL}",
    "install:browsers": "playwright install",
    "smoke": "node smoke.js",
    "docker:build": "docker build -t qa-smoke .",
    "docker:run": "docker run -p 3000:3000 qa-smoke"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "connect-flash": "^0.1.1",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "pg": "^8.11.3",
    "uuid": "^13.0.0"
  }
}